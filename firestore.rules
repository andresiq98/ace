rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ USERS ═══
    // Authenticated users can read any profile.
    // Users can only write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // ═══ GROUPS ═══
    // Any authenticated user can read groups (needed for join by invite code).
    // Any authenticated user can create a group.
    // Members can update; also allow update if user is joining (adding self to memberIds).
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || request.auth.uid in request.resource.data.memberIds);

      // ═══ MATCHES (subcollection of group) ═══
      // Only group members can read and create matches.
      match /matches/{matchId} {
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }

      // ═══ LEADERBOARD (subcollection of group) ═══
      // Any authenticated user can read (for share cards).
      // Any authenticated user can write (needed for join flow creating own entry + match updates).
      match /leaderboard/{entryId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds
              || request.auth.uid == entryId);
      }

      // ═══ SCHEDULED MATCHES (subcollection of group) ═══
      match /scheduledMatches/{matchId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }
    }
  }
}
